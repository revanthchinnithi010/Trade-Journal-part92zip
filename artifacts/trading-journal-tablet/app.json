{
  "expo": {
    "name": "TradeVault",
    "slug": "tradevault",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "tradevault",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.tradevault.app"
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.tradevault.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0d1117"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}