# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (auto-provisioned on Replit)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Session ──────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret

# ─── Market Data Providers ───────────────────────────────────────────────────
# Finnhub (Forex + Indices): https://finnhub.io — free tier available
FINNHUB_API_KEY=

# ─── Telegram Alerts (optional) ──────────────────────────────────────────────
# Create a bot via @BotFather, then get your Chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
